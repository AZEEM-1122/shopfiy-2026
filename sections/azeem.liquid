{%- style -%}
  @keyframes fadeInUp {
    0% {
      opacity: 0;
      transform: translateY(30px);
      letter-spacing: 0.2em;
    }
    100% {
      opacity: 1;
      transform: translateY(0);
      letter-spacing: 0.05em;
    }
  }

  .fade-in-up {
    animation: fadeInUp 0.8s ease-out forwards;
    opacity: 0;
    transform: translateY(30px);
    letter-spacing: 0.2em;
  }
{%- endstyle -%}

<section class="custom-heading">
  <h1 class="fade-in-up">{{ section.settings.heading_text }}</h1>
</section>

{% schema %}
{
  "name": "Custom Heading",
  "settings": [
    {
      "type": "text",
      "id": "heading_text",
      "label": "Heading Text",
      "default": "Hello syed"
    }
  ],
  "presets": [
    {
      "name": "Custom azeem"
    }
  ]
}
{% endschema %}